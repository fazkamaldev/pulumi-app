FROM node:20-alpine as build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
ARG INIT_SETTINGS_API_URL
ARG INIT_BRAND_API_URL
ARG INIT_CAR_API_URL
ENV INIT_SETTINGS_API_URL=$INIT_SETTINGS_API_URL
ENV INIT_BRAND_API_URL=$INIT_BRAND_API_URL
ENV INIT_CAR_API_URL=$INIT_CAR_API_URL
RUN npm run build

FROM nginx:1.25-alpine
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80